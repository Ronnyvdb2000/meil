# Kopieer dit bestand naar ".env" en vul je eigen gegevens in
# .env wordt NIET in git/version control gezet (zet in .gitignore!)

# --- IMAP instellingen (Online.be / Proximedia) ---
IMAP_HOST=imap.online.be
IMAP_PORT=993
IMAP_USER=jouw_volledige_email@domein.be
IMAP_PASS=jouw_wachtwoord

# --- Turso instellingen ---
# Aanmaken met: turso db create mail-archief
# URL ophalen met: turso db show mail-archief --url
# Token aanmaken met: turso db tokens create mail-archief
TURSO_DATABASE_URL=libsql://mail-archief-jouwnaam.turso.io
TURSO_AUTH_TOKEN=

# --- Lokale opslag voor attachments ---
ATTACHMENT_DIR=./attachments
